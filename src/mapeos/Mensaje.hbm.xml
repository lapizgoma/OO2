<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping SYSTEM "../hibernate-mapping-3.0.dtd">
<hibernate-mapping>
	<class name="model.Mensaje" table="mensaje">
		<id column="id" name="id">
			<generator class="identity"/>
		</id>
		<property name="contenido" type="string" column="contenido"/>
		<property name="fecha" column="fecha" type="java.time.LocalDateTime"/>
		<many-to-one name="usuario" class="model.Usuario" column="usuario_id" not-null="true"/>
		<many-to-one name="ticket" class="model.Ticket" column="id_ticket" not-null="true" lazy="false"></many-to-one>
	</class>
</hibernate-mapping>