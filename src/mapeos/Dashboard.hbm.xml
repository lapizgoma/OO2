<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping SYSTEM "../hibernate-mapping-3.0.dtd">
<hibernate-mapping>
	<class name="model.Dashboard" table="dashboard">
		<id column="id" name="id">
			<generator class="identity"/>
		</id>
		<many-to-one name="empleado" class="model.Empleado" not-null="true"></many-to-one>
		<bag name="tickets" table="Ticket">
			<key column="dashboard_id"/>
			<one-to-many class="model.Ticket"/>
		</bag>
	</class>
</hibernate-mapping>